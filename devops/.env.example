# ==============================================================================
# PulsarCD - Environment Configuration
# Copy this file to .env and fill in your values before deploying
# ==============================================================================

# ==============================================================================
# Docker Registry Configuration
# ==============================================================================
# Your private Docker registry URL (without https://)
DOCKER_REGISTRY_URL=registry.example.com
# Registry credentials for push/pull operations
DOCKER_REGISTRY_USERNAME=myuser
DOCKER_REGISTRY_PASSWORD=mypassword

# ==============================================================================
# Traefik / Domain Configuration
# ==============================================================================
# Public hostname for the PulsarCD web interface
TRAEFIK_HOST=logs.example.com

# ==============================================================================
# Node Placement (Swarm hostnames)
# ==============================================================================
# Node where OpenSearch should be deployed
OPENSEARCH_NODE_HOSTNAME=node-1
# Node where the Backend should be deployed
BACKEND_NODE_HOSTNAME=node-2

# ==============================================================================
# SSH Configuration
# ==============================================================================
# Path to SSH keys on the host (mounted for SSH access to build/deploy)
SSH_KEYS_PATH=/home/myuser/.ssh

# ==============================================================================
# GitHub Integration (for Stacks tab)
# ==============================================================================
# GitHub Personal Access Token (with repo access)
PULSARCD_GITHUB__TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GitHub username
PULSARCD_GITHUB__USERNAME=myusername
# Git commit email
PULSARCD_GITHUB__USEREMAIL=myemail@example.com
# Path on host where repos are cloned
PULSARCD_GITHUB__REPOS_PATH=/home/myuser
# Path to deployment scripts
PULSARCD_GITHUB__REPOS_PATH=/home/myuser/repos
# SSH host for build/deploy commands (usually dockerhost for host-gateway)
PULSARCD_GITHUB__SSH_HOST=dockerhost
# SSH username for build/deploy commands
PULSARCD_GITHUB__SSH_USER=myuser
# Which repos to show in Stacks: "all" (default) or "starred"
#PULSARCD_GITHUB__REPOS_MODE=all

# ==============================================================================
# Authentication
# ==============================================================================
# Login credentials for the web interface
PULSARCD_AUTH__USERNAME=admin
PULSARCD_AUTH__PASSWORD=changeme
# JWT secret key (leave empty to auto-generate on each restart)
PULSARCD_AUTH__JWT_SECRET=
# Token expiry in hours
PULSARCD_AUTH__JWT_EXPIRY_HOURS=24
# Shared key for agent-to-backend API auth (leave empty to auto-generate on each restart)
PULSARCD_AUTH__AGENT_KEY=

# ==============================================================================
# AI / vLLM Configuration
# ==============================================================================
# vLLM API URL (OpenAI-compatible endpoint)
VLLM_URL=http://vllm-dev-service:8000
# Model to use for AI features (HuggingFace model ID)
VLLM_MODEL=Qwen/Qwen3.5-122B-A10B
# Context window size in tokens (must match model's actual limit)
#PULSARCD_LLM__CONTEXT_TOKENS=128000
# Maximum output tokens per LLM response
#PULSARCD_LLM__MAX_OUTPUT_TOKENS=16384

# ==============================================================================
# Retention Configuration
# ==============================================================================
# Number of days to retain logs
LOG_RETENTION_DAYS=7

# ==============================================================================
# Tag Cleanup (optional, disabled by default)
# ==============================================================================
# Enable automatic cleanup of old git tags and Docker registry images
#PULSARCD_TAG_CLEANUP_ENABLED=false
# Dry-run mode: log what would be deleted without actually deleting (default: true)
#PULSARCD_TAG_CLEANUP_DRY_RUN=true
# Delete tags older than this many days (default: 30)
#PULSARCD_TAG_CLEANUP_MAX_AGE_DAYS=30
# How often to run the cleanup cycle, in hours (default: 24)
#PULSARCD_TAG_CLEANUP_INTERVAL_HOURS=24
# Always keep at least this many recent tags per repo (default: 5)
#PULSARCD_TAG_CLEANUP_KEEP_LATEST_N=5