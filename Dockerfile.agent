# PulsarCD Agent Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    procps \
    curl \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install AMD ROCm SMI for GPU monitoring (amd64 only — not available on ARM)
RUN if [ "$(dpkg --print-architecture)" = "amd64" ]; then \
        curl -fsSL https://repo.radeon.com/rocm/rocm.gpg.key | gpg --dearmor -o /usr/share/keyrings/rocm-archive-keyring.gpg \
        && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/rocm-archive-keyring.gpg] https://repo.radeon.com/rocm/apt/latest jammy main" > /etc/apt/sources.list.d/rocm.list \
        && apt-get update \
        && apt-get install -y --no-install-recommends rocm-smi-lib \
        && rm -rf /var/lib/apt/lists/* \
        || (echo "ROCm install skipped (repo unavailable)" && rm -rf /var/lib/apt/lists/*); \
    else \
        echo "ROCm install skipped (ARM architecture — not supported)"; \
    fi

# Add ROCm to PATH (no-op if not installed)
ENV PATH="/opt/rocm/bin:${PATH}"
ENV LD_LIBRARY_PATH="/opt/rocm/lib:/opt/rocm/lib64${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

# NVIDIA GPU: nvidia-smi is injected at runtime by the NVIDIA Container Toolkit.
# No install needed here — just ensure NVIDIA_VISIBLE_DEVICES is set in docker-compose.

# Install Python dependencies
COPY agent/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy shared utilities and agent code
COPY shared/ ./shared/
COPY agent/ ./agent/

# Environment variables (override at runtime)
ENV AGENT_AGENT_ID=agent-default
ENV AGENT_BACKEND_URL=http://localhost:8000
ENV AGENT_OPENSEARCH__HOSTS=["http://localhost:9200"]
ENV AGENT_DOCKER_URL=unix:///var/run/docker.sock
ENV AGENT_LOG_LEVEL=INFO

# Run the agent
CMD ["python", "-m", "agent.main"]
